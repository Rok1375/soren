# Frontend -> backend signaling server URL.
# Local development default used by client/src/hooks/useWalkieTalkie.js:
# VITE_SIGNALING_URL=http://localhost:3001
# Production example after deploying backend:
# VITE_SIGNALING_URL=https://your-backend-url.onrender.com
VITE_SIGNALING_URL=http://localhost:3001

# WebRTC ICE configuration.
# STUN is enabled by default so local/demo peer discovery works without extra setup.
# Do not add TURN yet unless real-device cellular/NAT tests prove it is needed.
VITE_STUN_URL=stun:stun.l.google.com:19302
VITE_TURN_URL=
VITE_TURN_USERNAME=
VITE_TURN_CREDENTIAL=
