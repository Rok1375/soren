# Backend port.
# Render/Railway usually inject PORT automatically; keep 3001 for local dev.
PORT=3001

# Exact deployed frontend origin allowed to connect by CORS/Socket.io.
# Local development example:
CLIENT_ORIGIN=http://localhost:5173
# Production example:
# CLIENT_ORIGIN=https://your-frontend-url.vercel.app
# Optional multiple origins for previews/local testing:
# CLIENT_ORIGIN=https://your-frontend-url.vercel.app,http://localhost:5173

# Rate limiting configuration for security and DoS protection
# HTTP rate limit: max requests per window per IP
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
# Socket.io: max simultaneous connections per IP
RATE_LIMIT_MAX_SOCKET_CONNECTIONS_PER_IP=10
# Socket.io: max channel join attempts per minute per socket
SOCKET_JOIN_RATE_LIMIT=30

# WebRTC configuration (required for cellular/strict NAT traversal)
# STUN servers (free, Google-provided)
VITE_STUN_URL=stun:stun.l.google.com:19302
# TURN server (required for reliable cellular connections - use coturn or Twilio)
# VITE_TURN_URL=turn:your-turn-server.com:3478
# VITE_TURN_USERNAME=your-turn-username
# VITE_TURN_CREDENTIAL=your-turn-password

# Signal server URL for client
# VITE_SIGNALING_URL=http://localhost:3001
